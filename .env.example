EDOOKIT_URL=https://your-school-login.edookit.net
EDOOKIT_USER=
EDOOKIT_PASS=

# Optional: set to "false" to launch a visible chromium window during login
# (useful for debugging the OIDC flow on a desktop). Default: true.
# EDOOKIT_HEADLESS_LOGIN=true

# Optional: override where session cookies are cached between runs.
# Default on macOS: ~/Library/Caches/edookit-mcp/cookies.json
# EDOOKIT_COOKIE_CACHE=/path/to/cookies.json

# Optional: disable cookie persistence entirely (chromium launches every run).
# EDOOKIT_NO_COOKIE_CACHE=true

# Optional: override the school's wall-clock timezone (IANA name). Edookit row
# dates are rendered in tenant-local time without an offset suffix; this value
# anchors them when generating ISO 8601 timestamps. Default: Europe/Prague.
# EDOOKIT_TIMEZONE=Europe/Prague

# Optional: run as a remote MCP server over Streamable HTTP on this address
# (endpoint path is /mcp). Default unset → local stdio transport for normal
# MCP-host usage. Set when running behind a TLS reverse proxy + OAuth gateway
# (e.g. systemd service binding 127.0.0.1:9000). The CLI flag --http overrides
# this env var when both are set.
# EDOOKIT_HTTP_ADDR=127.0.0.1:9000

# Optional: allow a plain http:// EDOOKIT_URL pointing at a non-loopback host.
# Off by default — a real Edookit tenant is always https, and http:// would put
# the session cookie on the wire in the clear. Loopback hosts (localhost /
# 127.0.0.1 / ::1) are always allowed without this. Only enable for a trusted
# local proxy / test server. Default: false.
# EDOOKIT_ALLOW_INSECURE_HTTP=false
