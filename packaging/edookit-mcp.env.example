# /etc/edookit-mcp/edookit-mcp.env — runtime config for the edookit-mcp systemd
# service. Edit, then: sudo systemctl restart edookit-mcp
#
# Mode 0640, owner root:edookit-mcp (the service user can read; nobody else).
# The package marks this file as conffile/%config(noreplace) so dnf/apt won't
# overwrite your edits on upgrade.

# Required: your school's Edookit URL.
EDOOKIT_URL=https://your-school-login.edookit.net

# Required: Plus4U identity (email or login name) + its password.
EDOOKIT_USER=
EDOOKIT_PASS=

# Required for a server install: keep chromedp headless (no desktop session).
EDOOKIT_HEADLESS_LOGIN=true

# Cache the OIDC session cookie under the systemd-managed CacheDirectory so a
# service restart doesn't trigger a fresh chromedp login each time.
EDOOKIT_COOKIE_CACHE=/var/cache/edookit-mcp/cookies.json

# Streamable HTTP listener — the systemd unit already passes --http
# 127.0.0.1:9000, so this is informational. Override via the unit if needed.
# EDOOKIT_HTTP_ADDR=127.0.0.1:9000

# Optional: how long an idle MCP session is kept before sweep.
# EDOOKIT_HTTP_SESSION_IDLE_TTL=1h

# Optional: timezone for parsing Edookit's tenant-local timestamps. Default
# Europe/Prague.
# EDOOKIT_TIMEZONE=Europe/Prague
